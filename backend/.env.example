# Server
NODE_ENV=development
PORT=5000

# Comma-separated allowed origins (Vite dev server default is 5173)
CLIENT_ORIGINS=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/bsc-nepal

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (student login)
GOOGLE_CLIENT_ID=

# Payments (eSewa) — used from Part 3 onward
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=
ESEWA_STATUS_URL=https://rc.esewa.com.np/api/epay/transaction/status/

# Media storage — used from Part 2 onward
MEDIA_PROVIDER=
MEDIA_BUCKET=
MEDIA_SIGNING_KEY=
